---
layout: comunidad-base.njk
title: Comunidad — TheNucleo
description: "Propuestas de la comunidad TheNucleo: ideas, servicios y herramientas votadas por agencias de marketing."
permalink: /comunidad/
---
<header>
  <span class="section-label">Comunidad pública</span>
  <h1 class="page-title">Lo que la comunidad <em>quiere construir</em>.</h1>
  <p class="page-sub">Propuestas votadas por agencias. Ideas, servicios y herramientas que la comunidad valida y financia colectivamente. Cualquiera puede entrar, votar, comentar y proponer.</p>
  <a href="/comunidad/nueva/" class="btn">Nueva propuesta</a>
</header>

<div class="filters" id="filters" style="margin-top:48px">
  <button class="active" data-tipo="all">Todas</button>
  <button data-tipo="idea">Ideas</button>
  <button data-tipo="servicio">Servicios</button>
  <button data-tipo="herramienta">Herramientas</button>
</div>

{% if comunidad.propuestas.length == 0 %}
  <div class="empty">
    <p>Aún no hay propuestas aprobadas.</p>
    <p><a href="/comunidad/nueva/" class="btn">Sé el primero en proponer</a></p>
  </div>
{% else %}
  <div class="grid" id="lista-propuestas">
    {% for p in comunidad.propuestas %}
      <article class="card propuesta" data-tipo="{{ p.tipo_propuesta }}" data-id="{{ p.id }}" data-slug="{{ p.slug }}">
        <div class="card-meta">
          <div style="display:flex;gap:8px;flex-wrap:wrap">
            <span class="tag tag-yellow">{{ p.tipo_propuesta }}</span>
            {% if p.estado == 'financiada' %}<span class="tag tag-accent">financiada</span>{% endif %}
          </div>
          <span class="meta-time">{{ p.fecha_publicacion | dateES }}</span>
        </div>

        <h3 class="card-title"><a href="/comunidad/{{ p.slug }}/">{{ p.titulo }}</a></h3>
        <p class="card-body">{{ p.descripcion | truncate(180) }}</p>

        {% if p.umbral_financiacion_pool %}
          <div class="pool-summary" style="margin-top:14px">
            <span><strong>{{ p.recaudado_pool or 0 }} €</strong> / {{ p.umbral_financiacion_pool }} €</span>
            <span>{{ p.comentarios_count }} comentarios</span>
          </div>
          <div class="progress"><div class="progress-bar" style="width:{{ ((p.recaudado_pool or 0) / p.umbral_financiacion_pool * 100) | round }}%"></div></div>
        {% endif %}

        <div class="card-row">
          <button class="vote-btn" data-vote-propuesta="{{ p.id }}">
            <span class="arrow">▲</span>
            <span data-vote-count>{{ p.votos }}</span>
          </button>
          <a class="muted" href="/comunidad/{{ p.slug }}/" style="font-family:var(--mono);font-size:11px;letter-spacing:.04em">Ver detalle &rarr;</a>
        </div>
      </article>
    {% endfor %}
  </div>
{% endif %}

{% block scripts %}
<script type="module" src="/assets/js/comunidad-listado.js"></script>
{% endblock %}
