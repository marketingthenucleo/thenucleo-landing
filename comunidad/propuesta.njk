---
layout: comunidad-base.njk
pagination:
  data: comunidad.propuestas
  size: 1
  alias: propuesta
permalink: "/comunidad/{{ propuesta.slug }}/"
eleventyComputed:
  title: "{{ propuesta.titulo }} — Comunidad TheNucleo"
  description: "{{ propuesta.descripcion | truncate(155) }}"
---
<a class="link muted" href="/comunidad/" style="font-family:'JetBrains Mono',monospace;font-size:0.85rem">← Comunidad</a>

<header style="margin-top:1rem">
  <div class="row">
    <span class="tag yellow">{{ propuesta.tipo_propuesta }}</span>
    {% if propuesta.estado == 'financiada' %}<span class="tag accent">financiada</span>{% endif %}
    <span class="meta">{{ propuesta.fecha_publicacion | dateES }}</span>
  </div>
  <h1 style="margin-top:0.75rem">{{ propuesta.titulo }}</h1>
</header>

<section class="card" data-id="{{ propuesta.id }}" data-slug="{{ propuesta.slug }}">
  <p>{{ propuesta.descripcion }}</p>

  {% if propuesta.problema %}
    <h3>Problema que resuelve</h3>
    <p>{{ propuesta.problema }}</p>
  {% endif %}

  {% if propuesta.beneficio %}
    <h3>Beneficio para la comunidad</h3>
    <p>{{ propuesta.beneficio }}</p>
  {% endif %}

  {% if propuesta.umbral_financiacion_pool %}
    <h3>Financiación del pool</h3>
    <div class="row" style="justify-content:space-between">
      <span class="muted">{{ propuesta.recaudado_pool or 0 }} € recaudados de {{ propuesta.umbral_financiacion_pool }} €</span>
      {% if propuesta.cotizacion_precio %}<span class="muted">Cotización: {{ propuesta.cotizacion_precio }} €</span>{% endif %}
    </div>
    <div class="progress"><div class="progress-bar" style="width:{{ ((propuesta.recaudado_pool or 0) / propuesta.umbral_financiacion_pool * 100) | round }}%"></div></div>
    <button id="aportar-btn" class="btn" disabled>Aportar al pool — próximamente</button>
    <p class="stripe-note">Los pagos al pool se activarán cuando la cuenta Stripe de producción esté operativa.</p>
  {% elif propuesta.precio_adhoc %}
    <h3>Precio individual</h3>
    <p class="muted">{{ propuesta.precio_adhoc }} € — disponible cuando la propuesta sea financiada.</p>
  {% endif %}

  <div class="row" style="justify-content:space-between;margin-top:1.25rem;border-top:1px solid var(--border);padding-top:1rem">
    <button class="vote-btn" data-vote-propuesta="{{ propuesta.id }}">
      <span data-vote-icon>▲</span>
      <span data-vote-count>{{ propuesta.votos }}</span>
      <span class="muted">votos</span>
    </button>
    <span class="muted" data-comentarios-count>{{ propuesta.comentarios_count }} comentarios</span>
  </div>
</section>

<section style="margin-top:2rem">
  <h2>Comentarios</h2>
  <div id="comentario-form-wrap" style="display:none">
    <form id="comentario-form">
      <label for="comentario-texto">Tu comentario</label>
      <textarea id="comentario-texto" required minlength="3" maxlength="2000" placeholder="Tu aportación a esta propuesta…"></textarea>
      <p class="muted" style="margin-top:0.4rem">Tu comentario pasará por moderación antes de publicarse.</p>
      <button class="btn" type="submit" style="margin-top:0.5rem">Enviar</button>
    </form>
    <div id="comentario-feedback"></div>
  </div>
  <div id="comentario-login-cta" style="display:none">
    <div class="alert info">Inicia sesión con Google para comentar.</div>
  </div>

  <div id="comentarios-lista" style="margin-top:1.25rem">
    <p class="muted">Cargando comentarios…</p>
  </div>
</section>

{% block scripts %}
<script type="module" src="/assets/js/comunidad-ficha.js"></script>
{% endblock %}
