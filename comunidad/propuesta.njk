---
layout: comunidad-base.njk
narrow: true
pagination:
  data: comunidad.propuestas
  size: 1
  alias: propuesta
permalink: "/comunidad/{{ propuesta.slug }}/"
eleventyComputed:
  title: "{{ propuesta.titulo }} — Comunidad TheNucleo"
  description: "{{ propuesta.descripcion | truncate(155) }}"
---
{% set umbral = propuesta.umbral_financiacion_pool or 0 %}
{% set recaudado = propuesta.recaudado_pool or 0 %}
{% set pct = 0 %}
{% if umbral > 0 %}{% set pct = (recaudado / umbral * 100) | round %}{% endif %}
{% set seccionUrl = "/comunidad/pool/" if propuesta.modo == "pool" else "/comunidad/referidos/" %}
{% set seccionLabel = "Pool de proyectos" if propuesta.modo == "pool" else "Desarrollo con Referidos" %}

<div class="page-header animate-in">
  <div>
    <a class="crumb" href="{{ seccionUrl }}">&larr; {{ seccionLabel }}</a>
    <div style="display:flex;gap:8px;flex-wrap:wrap;margin:4px 0 12px">
      {% if propuesta.modo == "pool" %}
        <span class="badge badge--pending" style="background:var(--accent-primary-muted);color:var(--accent-primary)">Pool</span>
      {% else %}
        <span class="badge badge--violet">Referidos</span>
      {% endif %}
      {% if propuesta.estado == "financiada" %}<span class="badge badge--done">{{ "Financiada" if propuesta.modo == "pool" else "Completado" }}</span>{% endif %}
    </div>
    <h1>{{ propuesta.titulo }}</h1>
    <div class="page-header-sub">{{ propuesta.fecha_publicacion | dateES }}</div>
  </div>
</div>

<section class="proposal-card animate-in" data-id="{{ propuesta.id }}" data-slug="{{ propuesta.slug }}">
  <p>{{ propuesta.descripcion }}</p>

  {% if propuesta.problema %}
    <h3 class="section-h3">Problema que resuelve</h3>
    <p>{{ propuesta.problema }}</p>
  {% endif %}

  {% if propuesta.beneficio %}
    <h3 class="section-h3">Beneficio para la comunidad</h3>
    <p>{{ propuesta.beneficio }}</p>
  {% endif %}

  {% if umbral > 0 %}
    <h3 class="section-h3">Financiación del pool</h3>
    <div class="proposal-progress">
      <div class="progress-bar-bg"><div class="progress-bar-fill" style="width:{{ pct }}%"></div></div>
      <div class="progress-info">
        <span class="progress-amount">{{ recaudado }} € / {{ umbral }} €</span>
        <span class="progress-pct">{{ pct }}%</span>
      </div>
    </div>
    {% if propuesta.cotizacion_precio %}<p class="muted">Cotización estimada: {{ propuesta.cotizacion_precio }} €</p>{% endif %}
    <button id="aportar-btn" class="btn btn--primary" disabled style="margin-top:18px">Aportar al pool — próximamente</button>
    <p class="muted" style="margin-top:8px;font-style:italic">Los pagos al pool se activarán cuando la cuenta Stripe de producción esté operativa.</p>
  {% elif propuesta.precio_adhoc %}
    <h3 class="section-h3">Precio individual</h3>
    <p class="muted">{{ propuesta.precio_adhoc }} € — disponible cuando la propuesta sea financiada.</p>
  {% endif %}

  <div class="proposal-footer" style="margin-top:18px">
    <div class="proposal-meta">
      <button type="button" class="vote-btn" data-vote-propuesta="{{ propuesta.id }}" aria-label="Votar">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        <span data-vote-count>{{ propuesta.votos }}</span>
        <span class="muted" style="font-weight:500">votos</span>
      </button>
    </div>
    <span class="proposal-time" data-comentarios-count>{{ propuesta.comentarios_count }} comentarios</span>
  </div>
</section>

<section style="margin-top:48px">
  <h2 class="section-h2">Comentarios</h2>
  <div id="comentario-form-wrap" style="display:none">
    <form id="comentario-form">
      <div class="input-group">
        <label class="input-label" for="comentario-texto">Tu comentario</label>
        <textarea class="input-field" id="comentario-texto" required minlength="3" maxlength="2000" placeholder="Tu aportación a esta propuesta…"></textarea>
        <div class="input-help">Tu comentario pasará por moderación antes de publicarse.</div>
      </div>
      <button class="btn btn--primary" type="submit">Enviar</button>
    </form>
    <div id="comentario-feedback"></div>
  </div>
  <div id="comentario-login-cta" style="display:none">
    <div class="alert alert--info">
      Inicia sesión con Google para comentar.
      <button type="button" class="btn btn--primary btn--sm" id="login-cta-btn" style="margin-left:8px">Entrar</button>
    </div>
  </div>

  <div id="comentarios-lista" style="margin-top:24px">
    <p class="muted">Cargando comentarios…</p>
  </div>
</section>

{% block scripts %}
<script type="module" src="/assets/js/comunidad-ficha.js"></script>
{% endblock %}
