<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ title or "Comunidad TheNucleo" }}</title>
  <meta name="description" content="{{ description or 'Comunidad pública de TheNucleo: propuestas, ideas y herramientas votadas por agencias de marketing.' }}" />
  <link rel="canonical" href="https://work.thenucleo.com{{ permalink }}" />
  <meta property="og:title" content="{{ title or 'Comunidad TheNucleo' }}" />
  <meta property="og:description" content="{{ description or 'Comunidad pública de TheNucleo' }}" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://work.thenucleo.com{{ permalink }}" />
  <meta property="og:image" content="https://work.thenucleo.com/Media/Logo_the_nucleo_circulo.png" />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/png" href="/Media/Logo_the_nucleo_circulo.png" />
  <script>
    window.__SUPABASE_URL__ = {{ site.supabaseUrl | dump | safe }};
    window.__SUPABASE_ANON_KEY__ = {{ site.supabaseAnonKey | dump | safe }};
    window.__EDGE_ADMIN_ACTION__ = {{ site.edgeFunctionAdminAction | dump | safe }};
  </script>
  <style>
    :root {
      --bg: #171717;
      --bg-elev: #1e1e1e;
      --yellow: #F3F959;
      --accent: #C7B299;
      --text: #E8EAE9;
      --text-bright: #ffffff;
      --muted: #8a8a8a;
      --border: #2a2a2a;
      --danger: #ef4444;
      --success: #22c55e;
    }
    * { box-sizing: border-box; }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Space Grotesk', sans-serif;
      max-width: 960px;
      margin: 0 auto;
      padding: 1.5rem 1.5rem 5rem;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }
    a { color: var(--yellow); text-decoration: none; }
    a:hover { opacity: 0.85; }
    h1, h2, h3 { color: var(--text-bright); line-height: 1.2; }
    h1 { font-size: clamp(1.8rem, 4vw, 2.4rem); margin: 0 0 0.5rem; }
    h2 { color: var(--yellow); font-size: 1.5rem; margin-top: 2.5rem; }
    h3 { font-size: 1.2rem; margin-top: 1.5rem; }
    .meta {
      color: var(--muted);
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.85rem;
    }
    nav.cnav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.5rem 0 1.5rem;
      border-bottom: 1px solid var(--border);
      margin-bottom: 2rem;
      flex-wrap: wrap;
      gap: 0.75rem;
    }
    nav.cnav .left { display: flex; gap: 1.25rem; align-items: center; flex-wrap: wrap; }
    nav.cnav a.brand {
      font-weight: 700;
      color: var(--text-bright);
      letter-spacing: -0.01em;
    }
    nav.cnav a.brand span { color: var(--yellow); }
    nav.cnav a.link {
      color: var(--muted);
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.85rem;
    }
    nav.cnav a.link:hover { color: var(--yellow); }
    nav.cnav a.link.active { color: var(--text-bright); }
    nav.cnav .right { display: flex; gap: 0.5rem; align-items: center; }
    button.btn, a.btn {
      display: inline-block;
      background: var(--yellow);
      color: var(--bg);
      padding: 0.55rem 1rem;
      border: 0;
      border-radius: 6px;
      font-weight: 600;
      cursor: pointer;
      font-family: inherit;
      font-size: 0.9rem;
    }
    button.btn-ghost, a.btn-ghost {
      background: transparent;
      color: var(--text);
      border: 1px solid var(--border);
    }
    button.btn-ghost:hover, a.btn-ghost:hover { border-color: var(--yellow); color: var(--yellow); }
    button.btn:disabled { opacity: 0.55; cursor: not-allowed; }
    .card {
      background: var(--bg-elev);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1.25rem;
      margin: 0.75rem 0;
    }
    .row { display: flex; gap: 0.75rem; align-items: center; flex-wrap: wrap; }
    .tag {
      display: inline-block;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      padding: 0.15rem 0.5rem;
      border-radius: 4px;
      border: 1px solid var(--border);
      color: var(--muted);
    }
    .tag.yellow { color: var(--yellow); border-color: var(--yellow); }
    .tag.accent { color: var(--accent); border-color: var(--accent); }
    .vote-btn {
      display: inline-flex;
      gap: 0.4rem;
      align-items: center;
      background: transparent;
      border: 1px solid var(--border);
      color: var(--text);
      padding: 0.4rem 0.7rem;
      border-radius: 6px;
      cursor: pointer;
      font-family: inherit;
      font-size: 0.85rem;
    }
    .vote-btn.voted { border-color: var(--yellow); color: var(--yellow); }
    .vote-btn:disabled { opacity: 0.5; cursor: not-allowed; }
    .progress {
      height: 6px;
      width: 100%;
      background: var(--border);
      border-radius: 4px;
      overflow: hidden;
      margin: 0.5rem 0;
    }
    .progress-bar {
      height: 100%;
      background: var(--yellow);
      transition: width 0.3s;
    }
    label { display: block; font-size: 0.85rem; color: var(--muted); margin: 0.75rem 0 0.25rem; }
    input, textarea, select {
      width: 100%;
      background: var(--bg);
      border: 1px solid var(--border);
      color: var(--text);
      padding: 0.6rem 0.75rem;
      border-radius: 6px;
      font-family: inherit;
      font-size: 0.95rem;
    }
    textarea { resize: vertical; min-height: 6rem; }
    .alert {
      padding: 0.75rem 1rem;
      border-radius: 6px;
      margin: 0.75rem 0;
      font-size: 0.9rem;
    }
    .alert.info { background: rgba(243,249,89,0.08); border: 1px solid rgba(243,249,89,0.3); color: var(--yellow); }
    .alert.error { background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.3); color: #fca5a5; }
    .alert.success { background: rgba(34,197,94,0.08); border: 1px solid rgba(34,197,94,0.3); color: #86efac; }
    .muted { color: var(--muted); font-size: 0.85rem; }
    .empty {
      text-align: center;
      padding: 3rem 1rem;
      color: var(--muted);
      border: 1px dashed var(--border);
      border-radius: 10px;
    }
    .grid { display: grid; gap: 0.75rem; }
    .filters { display: flex; gap: 0.5rem; flex-wrap: wrap; margin: 1rem 0 1.5rem; }
    .filters button {
      background: transparent;
      border: 1px solid var(--border);
      color: var(--muted);
      padding: 0.35rem 0.75rem;
      border-radius: 999px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.75rem;
      cursor: pointer;
    }
    .filters button.active { background: var(--yellow); color: var(--bg); border-color: var(--yellow); }
    .comment {
      border-left: 2px solid var(--border);
      padding: 0.5rem 0 0.5rem 1rem;
      margin: 0.75rem 0;
    }
    .comment .author { font-size: 0.8rem; color: var(--muted); }
    .stripe-note { font-size: 0.75rem; color: var(--muted); margin-top: 0.4rem; font-style: italic; }
  </style>
</head>
<body>
  <nav class="cnav">
    <div class="left">
      <a class="brand" href="/">The<span>Nucleo</span></a>
      <a class="link {% if page.url == '/comunidad/' %}active{% endif %}" href="/comunidad/">Comunidad</a>
      <a class="link {% if page.url == '/comunidad/nueva/' %}active{% endif %}" href="/comunidad/nueva/">Nueva propuesta</a>
      <a class="link" href="/conocimiento-zenyx/">Conocimiento</a>
    </div>
    <div class="right">
      <span id="auth-status" class="muted" style="display:none">cargando…</span>
      <button id="auth-login" class="btn btn-ghost" style="display:none">Entrar con Google</button>
      <button id="auth-logout" class="btn btn-ghost" style="display:none">Salir</button>
    </div>
  </nav>

  {{ content | safe }}

  <script type="module" src="/assets/js/comunidad-supabase.js"></script>
  {% block scripts %}{% endblock %}
  <script defer src="/assets/js/consent.js"></script>
</body>
</html>
