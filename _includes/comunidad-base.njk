  {% if not hideModal %}
  <!-- Modal global: Crear propuesta. Disponible en /comunidad/* salvo si la página define hideModal=true. -->
  <div class="modal-overlay" id="modalPropuesta" onclick="if(event.target===this){this.classList.remove('visible')}">
    <div class="modal">
      <div class="modal-header">
        <h3>Crear tu propuesta</h3>
        <button class="modal-close" type="button" onclick="document.getElementById('modalPropuesta').classList.remove('visible')" aria-label="Cerrar">&times;</button>
      </div>
      <form id="modal-propuesta-form" novalidate>
        <div class="modal-body">
          <div id="modal-login-cta" class="alert alert--info" style="display:none">
            Para enviar una propuesta necesitas iniciar sesión con Google.
            <button type="button" class="btn btn--primary btn--sm" id="modal-login-btn" style="margin-left:8px">Iniciar sesión</button>
          </div>
          <div id="modal-form-fields">
            <div class="input-group">
              <label class="input-label" for="modal-modo">Modo <span class="required">*</span></label>
              <select class="input-field" id="modal-modo" required>
                <option value="pool">Pool de Proyectos (financiación colectiva)</option>
                <option value="referidos">Desarrollo con Referidos (individual)</option>
              </select>
            </div>
            <div class="input-group">
              <label class="input-label" for="modal-titulo">Título <span class="required">*</span></label>
              <input type="text" class="input-field" id="modal-titulo" placeholder="Nombre de tu propuesta" required minlength="6" maxlength="120">
            </div>
            <div class="input-group">
              <label class="input-label" for="modal-descripcion">Descripción <span class="required">*</span></label>
              <textarea class="input-field" id="modal-descripcion" placeholder="Describe brevemente tu idea…" required minlength="20" maxlength="2000"></textarea>
              <div class="input-help">Cuantos más detalles mejor podremos costear la propuesta.</div>
            </div>
            <div class="input-group">
              <label class="input-label" for="modal-problema">Problema que resuelve <span class="required">*</span></label>
              <textarea class="input-field" id="modal-problema" placeholder="¿Qué dolor o limitación tienes actualmente?" required minlength="10" maxlength="1000" style="min-height:80px"></textarea>
            </div>
            <div class="input-group">
              <label class="input-label" for="modal-beneficio">Beneficio esperado</label>
              <textarea class="input-field" id="modal-beneficio" placeholder="¿Qué mejoraría concretamente en tu operación?" maxlength="1000" style="min-height:80px"></textarea>
            </div>
            <div id="modal-pool-fields">
              <div class="input-group">
                <label class="input-label" for="modal-cotizacion">Cotización estimada (€)</label>
                <input type="number" class="input-field" id="modal-cotizacion" min="0" step="1">
              </div>
              <div class="input-group">
                <label class="input-label" for="modal-umbral">Umbral del pool (€)</label>
                <input type="number" class="input-field" id="modal-umbral" min="0" step="1" placeholder="Cuánto hay que recaudar para liberarlo">
              </div>
            </div>
            <div id="modal-feedback"></div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn--secondary" onclick="document.getElementById('modalPropuesta').classList.remove('visible')">Cancelar</button>
          <button type="submit" class="btn btn--primary" id="modal-submit">Publicar propuesta</button>
        </div>
      </form>
    </div>
  </div>
  {% endif %}

  <script>
    // Nav scrolled state (idéntico a la landing)
    (function () {
      var nav = document.getElementById('nav');
      if (!nav) return;
      var update = function () { nav.classList.toggle('scrolled', (window.scrollY || 0) > 40); };
      window.addEventListener('scroll', update, { passive: true });
      update();
    })();
    // Helpers para abrir/cerrar modal desde botones inline
    window.openComunidadModal = function (modo) {
      var ov = document.getElementById('modalPropuesta');
      if (!ov) return;
      if (modo) {
        var sel = document.getElementById('modal-modo');
        if (sel) sel.value = modo;
        var ev = new Event('change', { bubbles: true });
        sel?.dispatchEvent(ev);
      }
      ov.classList.add('visible');
    };
    window.closeComunidadModal = function () { document.getElementById('modalPropuesta')?.classList.remove('visible'); };
  </script>
