    :root {
      --bg: #171717;
      --yellow: #F3F959;
      --accent: #C7B299;
      --text: #E8EAE9;
      --text-bright: #ffffff;
      --muted: #8a8a8a;
      --border: #2a2a2a;
    }
    * { box-sizing: border-box; }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Space Grotesk', sans-serif;
      max-width: 720px;
      margin: 0 auto;
      padding: 96px 1.5rem 5rem;
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
    }
    h1 {
      color: var(--text-bright);
      font-size: clamp(1.8rem, 4vw, 2.4rem);
      line-height: 1.2;
      margin: 0 0 0.5rem;
    }
    h2, h3 {
      color: var(--yellow);
      margin-top: 2.5rem;
      line-height: 1.3;
    }
    h2 { font-size: 1.5rem; }
    h3 { font-size: 1.2rem; }
    a { color: var(--yellow); text-decoration: underline; text-underline-offset: 3px; }
    a:hover { opacity: 0.85; }
    /* Reset enlaces dentro del nav (el rule global de arriba les pone underline + yellow) */
    #nav a, #nav a:hover { text-decoration: none; opacity: 1; color: inherit; }
    #nav .nav-links a { color: var(--text-secondary); }
    #nav .nav-links a:hover { color: var(--text-primary); }
    #nav .nav-links a.active { color: var(--accent-primary); }
    p { margin: 1rem 0; }
    ul, ol { padding-left: 1.5rem; }
    li { margin: 0.4rem 0; }
    .meta {
      color: var(--muted);
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.85rem;
      margin: 0.5rem 0 2rem;
    }
    .back {
      display: inline-block;
      color: var(--muted);
      text-decoration: none;
      font-size: 0.9rem;
      margin-bottom: 2rem;
      font-family: 'JetBrains Mono', monospace;
    }
    .back:hover { color: var(--yellow); }
    .video {
      aspect-ratio: 16 / 9;
      margin: 2rem 0;
      background: #000;
      border-radius: 8px;
      overflow: hidden;
    }
    .video iframe { width: 100%; height: 100%; border: 0; }
    blockquote {
      border-left: 3px solid var(--yellow);
      padding: 0.2rem 0 0.2rem 1rem;
      color: var(--accent);
      margin: 1.5rem 0;
      font-style: italic;
    }
    code {
      background: #2a2a2a;
      padding: 0.1em 0.35em;
      border-radius: 3px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.9em;
    }
    pre {
      background: #0f0f0f;
      border: 1px solid var(--border);
      padding: 1rem;
      border-radius: 6px;
      overflow-x: auto;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.85rem;
    }
    pre code { background: transparent; padding: 0; }
    hr { border: 0; border-top: 1px solid var(--border); margin: 3rem 0; }
    .footer-cta {
      margin-top: 4rem;
      padding: 2rem;
      background: #1e1e1e;
      border: 1px solid var(--border);
      border-radius: 8px;
      text-align: center;
    }
    .footer-cta a {
      display: inline-block;
      background: var(--yellow);
      color: var(--bg);
      padding: 0.8rem 1.5rem;
      border-radius: 6px;
      text-decoration: none;
      font-weight: 600;
      margin-top: 0.5rem;
    }
  </style>
</head>
