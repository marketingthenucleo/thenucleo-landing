<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ title }} — Conocimiento Zenyx | TheNucleo</title>
  <meta name="description" content="{{ excerpt }}" />
  <link rel="canonical" href="https://work.thenucleo.com/conocimiento-zenyx/{{ slug }}/" />
  <meta property="og:title" content="{{ title }}" />
  <meta property="og:description" content="{{ excerpt }}" />
  <meta property="og:type" content="article" />
  <meta property="og:url" content="https://work.thenucleo.com/conocimiento-zenyx/{{ slug }}/" />
  <meta property="og:image" content="https://work.thenucleo.com/Media/Logo_the_nucleo_circulo.png" />
  <meta property="article:published_time" content="{{ date | isoDate }}" />
  <meta property="article:author" content="TheNucleo" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{ title }}" />
  <meta name="twitter:description" content="{{ excerpt }}" />
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": {{ title | dump | safe }},
    "description": {{ excerpt | dump | safe }},
    "datePublished": "{{ date | isoDate }}",
    "author": { "@type": "Organization", "name": "TheNucleo", "url": "https://work.thenucleo.com/" },
    "publisher": { "@type": "Organization", "name": "TheNucleo", "url": "https://work.thenucleo.com/", "logo": { "@type": "ImageObject", "url": "https://work.thenucleo.com/Media/Logo_the_nucleo_circulo.png" } },
    "mainEntityOfPage": "https://work.thenucleo.com/conocimiento-zenyx/{{ slug }}/"
  }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/png" href="/Media/Logo_the_nucleo_circulo.png" />
  <style>
    :root {
      --bg: #171717;
      --yellow: #F3F959;
      --accent: #C7B299;
      --text: #E8EAE9;
      --text-bright: #ffffff;
      --muted: #8a8a8a;
      --border: #2a2a2a;
    }
    * { box-sizing: border-box; }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Space Grotesk', sans-serif;
      max-width: 720px;
      margin: 0 auto;
      padding: 3rem 1.5rem 5rem;
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
    }
    h1 {
      color: var(--text-bright);
      font-size: clamp(1.8rem, 4vw, 2.4rem);
      line-height: 1.2;
      margin: 0 0 0.5rem;
    }
    h2, h3 {
      color: var(--yellow);
      margin-top: 2.5rem;
      line-height: 1.3;
    }
    h2 { font-size: 1.5rem; }
    h3 { font-size: 1.2rem; }
    a { color: var(--yellow); text-decoration: underline; text-underline-offset: 3px; }
    a:hover { opacity: 0.85; }
    p { margin: 1rem 0; }
    ul, ol { padding-left: 1.5rem; }
    li { margin: 0.4rem 0; }
    .meta {
      color: var(--muted);
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.85rem;
      margin: 0.5rem 0 2rem;
    }
    .back {
      display: inline-block;
      color: var(--muted);
      text-decoration: none;
      font-size: 0.9rem;
      margin-bottom: 2rem;
      font-family: 'JetBrains Mono', monospace;
    }
    .back:hover { color: var(--yellow); }
    .video {
      aspect-ratio: 16 / 9;
      margin: 2rem 0;
      background: #000;
      border-radius: 8px;
      overflow: hidden;
    }
    .video iframe { width: 100%; height: 100%; border: 0; }
    blockquote {
      border-left: 3px solid var(--yellow);
      padding: 0.2rem 0 0.2rem 1rem;
      color: var(--accent);
      margin: 1.5rem 0;
      font-style: italic;
    }
    code {
      background: #2a2a2a;
      padding: 0.1em 0.35em;
      border-radius: 3px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.9em;
    }
    pre {
      background: #0f0f0f;
      border: 1px solid var(--border);
      padding: 1rem;
      border-radius: 6px;
      overflow-x: auto;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.85rem;
    }
    pre code { background: transparent; padding: 0; }
    hr { border: 0; border-top: 1px solid var(--border); margin: 3rem 0; }
    .footer-cta {
      margin-top: 4rem;
      padding: 2rem;
      background: #1e1e1e;
      border: 1px solid var(--border);
      border-radius: 8px;
      text-align: center;
    }
    .footer-cta a {
      display: inline-block;
      background: var(--yellow);
      color: var(--bg);
      padding: 0.8rem 1.5rem;
      border-radius: 6px;
      text-decoration: none;
      font-weight: 600;
      margin-top: 0.5rem;
    }
  </style>
</head>
<body>
  <a class="back" href="/conocimiento-zenyx/">← Todos los artículos</a>
  <h1>{{ title }}</h1>
  <p class="meta">{{ date | dateES }}</p>
  {{ content | safe }}
  <div class="footer-cta">
    <p style="margin:0;color:var(--muted);font-size:0.9rem">¿Quieres el portal de gestión disponible para más de 150 agencias?</p>
    <a href="/">Conoce TheNucleo</a>
  </div>
</body>
</html>
