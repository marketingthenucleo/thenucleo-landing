    :root {
      --kb-bg: #171717;
      --kb-card: #1e1e1e;
      --kb-card-hover: #232323;
      --kb-yellow: #F3F959;
      --kb-accent: #C7B299;
      --kb-text: #E8EAE9;
      --kb-text-bright: #ffffff;
      --kb-muted: #8a8a8a;
      --kb-border: #2a2a2a;
      --kb-border-strong: #3a3a3a;
    }
    body {
      background: var(--kb-bg);
