    }

    /* ── Header / intro ─────────────────────────── */
    .kb-header { margin: 2rem 0 2.5rem; max-width: 720px; }
    .kb-eyebrow {
      color: var(--kb-yellow);
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.75rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin: 0 0 0.75rem;
    }
    .kb-h1 {
      color: var(--kb-text-bright);
      font-size: clamp(2.2rem, 5vw, 3rem);
      margin: 0 0 1rem;
      line-height: 1.1;
      font-weight: 700;
      letter-spacing: -0.02em;
    }
    .kb-h1 em { color: var(--kb-yellow); font-style: normal; }
    .kb-intro {
      color: var(--kb-muted);
      font-size: 1.05rem;
      margin: 0;
      line-height: 1.55;
    }
    .kb-stats {
      display: flex;
      gap: 2rem;
      margin-top: 1.5rem;
      flex-wrap: wrap;
    }
    .kb-stat {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }
    .kb-stat-num {
      font-size: 1.5rem;
      font-weight: 600;
      color: var(--kb-text-bright);
      line-height: 1;
    }
    .kb-stat-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      color: var(--kb-muted);
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    /* ── Grid ───────────────────────────────────── */
    .kb-grid {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }
    @media (max-width: 960px) { .kb-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 600px) { .kb-grid { grid-template-columns: 1fr; gap: 1rem; } }

    /* ── Card ───────────────────────────────────── */
    .kb-card {
      position: relative;
      background: var(--kb-card);
      border: 1px solid var(--kb-border);
      border-radius: 12px;
      overflow: hidden;
      transition: transform 200ms cubic-bezier(0.16, 1, 0.3, 1),
                  border-color 200ms,
                  background 200ms;
    }
    .kb-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 2px;
      background: linear-gradient(90deg, var(--kb-yellow) 0%, transparent 60%);
      opacity: 0;
      transition: opacity 200ms;
    }
    .kb-card:hover,
    .kb-card:focus-within {
      transform: translateY(-3px);
      border-color: var(--kb-border-strong);
      background: var(--kb-card-hover);
    }
    .kb-card:hover::before,
    .kb-card:focus-within::before { opacity: 1; }

    .kb-card-link {
      display: flex;
      flex-direction: column;
      gap: 0.65rem;
      padding: 1.5rem 1.4rem 1.4rem;
      color: inherit;
      text-decoration: none;
      height: 100%;
    }
    .kb-card-link:focus-visible { outline: 2px solid var(--kb-yellow); outline-offset: -2px; border-radius: 12px; }

    .kb-card-meta {
      color: var(--kb-muted);
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }
    .kb-card-title {
      color: var(--kb-text-bright);
      font-size: 1.05rem;
      font-weight: 600;
      line-height: 1.35;
      margin: 0;
      /* line-clamp 3 */
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
      transition: color 200ms;
    }
    .kb-card:hover .kb-card-title { color: var(--kb-yellow); }
    .kb-card-excerpt {
      color: var(--kb-muted);
      font-size: 0.875rem;
      line-height: 1.55;
      margin: 0;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .kb-card-cta {
      margin-top: auto;
      padding-top: 0.75rem;
      color: var(--kb-yellow);
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.75rem;
      letter-spacing: 0.04em;
      opacity: 0.7;
      transition: opacity 200ms, transform 200ms;
    }
    .kb-card:hover .kb-card-cta { opacity: 1; transform: translateX(2px); }

    .kb-empty {
      grid-column: 1 / -1;
      text-align: center;
      color: var(--kb-muted);
      padding: 3rem 1rem;
      border: 1px dashed var(--kb-border);
      border-radius: 12px;
      font-style: italic;
    }

    @media (prefers-reduced-motion: reduce) {
      .kb-card, .kb-card::before, .kb-card-title, .kb-card-cta { transition: none !important; }
      .kb-card:hover { transform: none; }
    }
  </style>
